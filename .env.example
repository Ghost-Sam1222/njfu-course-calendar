# Copy to .env for local testing. Do not commit .env.
JW_BASE_URL=https://jwxt.njfu.edu.cn
JW_USERNAME=replace-with-your-student-id
JW_PASSWORD=replace-with-your-password

# Optional. If omitted, the script infers it from today's date.
# Example for spring 2026:
JW_SEMESTER=2025-2026-2

# Required for date calculation. This is the Monday of teaching week 1.
# Replace this with the real first Monday from the school calendar.
TERM_FIRST_MONDAY=2026-02-23

# Optional knobs.
TERM_WEEKS=20
CALENDAR_NAME=南林课表
CALENDAR_TIMEZONE=Asia/Shanghai

# Comma-separated dates or ranges to skip for normal classes.
# Example:
# EXCLUDE_DATES=2026-04-04..2026-04-06,2026-05-01..2026-05-05,2026-06-19
EXCLUDE_DATES=

# Automatically skip legal holidays from an external iCalendar source.
# Defaults to YangH9/ChinaCalendar when HOLIDAY_ICS_URLS is empty.
AUTO_EXCLUDE_HOLIDAYS=true
HOLIDAY_ICS_URLS=

# Experimental: add final exam arrangements if the school's exam page is available.
INCLUDE_EXAMS=false
EXAM_URLS=
