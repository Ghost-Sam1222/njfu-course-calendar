# Copy to .env for local testing. Do not commit .env.
JW_BASE_URL=https://jwxt.njfu.edu.cn
JW_USERNAME=2450802111
JW_PASSWORD=replace-with-your-password

# Optional. If omitted, the script infers it from today's date.
# Example for spring 2026:
JW_SEMESTER=2025-2026-2

# Required for date calculation. This is the Monday of teaching week 1.
# Replace this with the real first Monday from the school calendar.
TERM_FIRST_MONDAY=2026-02-23

# Optional knobs.
TERM_WEEKS=20
CALENDAR_NAME=南林课表
CALENDAR_TIMEZONE=Asia/Shanghai
